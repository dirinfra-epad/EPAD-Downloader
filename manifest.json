{
  "manifest_version": 3,
  "name": "EPAD Downloader",
  "version": "3.0.1",
  "description": "Baixa documentos automaticamente com nomes organizados no SIGADAER e SILOMS.",
  "permissions": ["scripting", "activeTab", "tabs", "storage"],
  "host_permissions": [
    "*://*.sigadaer.intraer/*",
    "*://*.siloms.intraer/*",
    "https://api.github.com/*",
    "https://dirinfra-epad.github.io/*"
  ],
  "action": {
    "default_title": "EPAD Downloader",
    "default_icon": "icon_inactive.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*.sigadaer.intraer/*", "*://*.siloms.intraer/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["popup/*", "releaseData.js", "icon.png"],
      "matches": ["*://*.sigadaer.intraer/*", "*://*.siloms.intraer/*"]
    }
  ],
  "icons": {
    "128": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
